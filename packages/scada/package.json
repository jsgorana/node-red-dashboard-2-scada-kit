{
  "name": "@jsgorana/node-red-dashboard-2-scada",
  "version": "1.0.0",
  "description": "HP-HMI / ISA-101 SCADA widget kit for Node-RED Dashboard 2.0 — SVG mimic/synoptic displays, equipment faceplates with RBAC, declarative tag bindings, and a built-in symbol library",
  "keywords": [
    "node-red",
    "node-red-dashboard",
    "node-red-dashboard-2",
    "scada",
    "hmi",
    "svg",
    "mimic",
    "synoptic",
    "faceplate",
    "symbols",
    "industrial",
    "iiot",
    "isa-101",
    "isa-18.2"
  ],
  "license": "Apache-2.0",
  "author": "jsgorana <jsgorana@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsgorana/node-red-dashboard-2-scada-kit.git",
    "directory": "packages/scada"
  },
  "bugs": {
    "url": "https://github.com/jsgorana/node-red-dashboard-2-scada-kit/issues"
  },
  "homepage": "https://github.com/jsgorana/node-red-dashboard-2-scada-kit#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "exports": {
    "./symbols": "./symbols/index.js"
  },
  "scripts": {
    "build": "rimraf resources && vite build -c vite.mimic.mjs && vite build -c vite.faceplate.mjs",
    "dev": "vite build -c vite.mimic.mjs --watch",
    "test": "vitest run"
  },
  "node-red": {
    "version": ">=4.0.0",
    "nodes": {
      "ui-scada-mimic": "nodes/ui-scada-mimic.js",
      "ui-scada-faceplate": "nodes/ui-scada-faceplate.js"
    }
  },
  "node-red-dashboard-2": {
    "version": ">=1.0.0",
    "widgets": {
      "ui-scada-mimic": {
        "output": "ui-scada-mimic.umd.js",
        "component": "UIScadaMimic"
      },
      "ui-scada-faceplate": {
        "output": "ui-scada-faceplate.umd.js",
        "component": "UIScadaFaceplate"
      }
    }
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "dompurify": "^3.1.6",
    "jsdom": "^24.1.3",
    "sanitize-html": "^2.13.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.0",
    "rimraf": "^5.0.0",
    "vite": "^8.1.2",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vitest": "^4.1.9"
  },
  "files": [
    "lib",
    "nodes",
    "symbols",
    "resources",
    "examples",
    "docs/assets",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
